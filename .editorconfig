root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Shell scripts: 2-space indent. shfmt reads these keys.
[*.{sh,bash}]
indent_style = space
indent_size = 2

# Go uses tabs by convention.
[*.go]
indent_style = tab

# Makefiles require tabs.
[Makefile]
indent_style = tab
