{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':configMigration',
    ':disableDependencyDashboard',
    'customManagers:helmChartYamlAppVersions',
    ':semanticCommitTypeAll(build)',
  ],

  // General Settings
  assigneesFromCodeOwners: true,
  baseBranchPatterns: [
    'main',
    '/^release\\/.*/',
  ],
  branchConcurrentLimit: 5,
  internalChecksFilter: 'strict',
  labels: [
    'dependencies',
  ],
  minimumReleaseAge: '7 days',
  postUpdateOptions: [
    'gomodTidy',
    'helmUpdateSubChartArchives',
    'npmDedupe',
  ],
  prCreation: 'not-pending',
  prHourlyLimit: 0,
  rangeStrategy: 'bump',
  rebaseWhen: 'behind-base-branch',

  // Specific Package Rules
  packageRules: [
    // Helm versioning applies to all updates (major included). Split from
    // the grouping rule below because Renovate disallows combining
    // matchUpdateTypes with versioning in a single rule.
    {
      matchManagers: ['helmv3'],
      versioning: 'helm',
    },
    {
      groupName: 'Helm Chart Support',
      groupSlug: 'helm-charts',
      matchManagers: ['helmv3'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },

    // Auto-merge every non-major update. Sets NO groupName on purpose: it only
    // controls merge policy. Grouping is owned by the per-manager rules below.
    // This split stops non-major updates from collapsing into one giant PR
    // where a single failing check blocks everything.
    {
      matchUpdateTypes: ['!major'],
      automerge: true,
    },
    // Group non-major GitHub Actions updates
    {
      groupName: 'non-major GitHub Actions',
      groupSlug: 'github-actions-non-major',
      matchManagers: ['github-actions'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },

    // Rust crate subcategories — listed before the catch-all so they take
    // precedence (later rules override groupName for matching packages).
    {
      groupName: 'Rust Dependencies',
      groupSlug: 'rust-deps',
      matchManagers: ['cargo'],
      matchUpdateTypes: ['!major'],
    },
    {
      groupName: 'Rust Kubernetes crates',
      groupSlug: 'rust-kubernetes',
      matchManagers: ['cargo'],
      matchPackageNames: ['/^kube/', '/^k8s/', '/^schemars/'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },
    {
      groupName: 'Rust Serde crates',
      groupSlug: 'rust-serde',
      matchManagers: ['cargo'],
      matchPackageNames: ['/^serde/'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },
    {
      groupName: 'Rust Tokio crates',
      groupSlug: 'rust-tokio',
      matchManagers: ['cargo'],
      matchPackageNames: ['/^tokio/'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },
    {
      groupName: 'Rust Tracing crates',
      groupSlug: 'rust-tracing',
      matchManagers: ['cargo'],
      matchPackageNames: ['/^tracing/'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },
    {
      groupName: 'Rust Axum crates',
      groupSlug: 'rust-axum',
      matchManagers: ['cargo'],
      matchPackageNames: ['/^axum/'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },
    // Servarr app API client crates — bump the integration family together.
    {
      groupName: 'Servarr API client crates',
      groupSlug: 'servarr-api-clients',
      matchManagers: ['cargo'],
      matchPackageNames: ['overseerr', 'sonarr', 'radarr', 'lidarr', 'prowlarr'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },
    {
      groupName: 'Rust Time crates',
      groupSlug: 'rust-time',
      matchManagers: ['cargo'],
      matchPackageNames: ['/^chrono/', '/^cron/'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },
    {
      groupName: 'Rust HTTP client crates',
      groupSlug: 'rust-http',
      matchManagers: ['cargo'],
      matchPackageNames: ['reqwest', 'url'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },
    {
      groupName: 'Rust Crypto crates',
      groupSlug: 'rust-crypto',
      matchManagers: ['cargo'],
      matchPackageNames: ['sha2', 'md-5', 'md5'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
    },
    // Dev/test dependencies. Placed AFTER the catch-all "Rust Dependencies"
    // rule on purpose: later rules win on groupName, so this is what splits
    // cargo dev crates (proptest, http, tower, temp-env) out of the main Rust
    // PR. depType is cargo's section name 'dev-dependencies' (hyphenated) — NOT
    // npm's 'devDependencies', which matches nothing here. matchUpdateTypes
    // keeps MAJOR dev bumps as individual reviewed PRs (the major-isolation
    // rule strips groupName, not automerge). NB: wiremock is declared in
    // [workspace.dependencies], so its depType is workspace.dependencies and
    // it groups under Rust Dependencies, not here.
    {
      groupName: 'auto-merge developer dependencies',
      groupSlug: 'dev-dependencies',
      matchDepTypes: ['dev-dependencies'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
      automerge: true,
    },

    // Rust toolchain version (from custom regex manager)
    {
      groupName: 'Rust Toolchain',
      groupSlug: 'rust-toolchain',
      matchDepNames: ['rust'],
      matchManagers: ['custom.regex'],
    },

    // Container image versions in image-defaults.toml
    {
      groupName: 'Servarr App Images',
      groupSlug: 'servarr-images',
      matchFileNames: ['image-defaults.toml'],
    },

    // Major isolation (most specific — placed LAST so it overrides the
    // groupName set by any rule above, including those without
    // matchUpdateTypes like Rust Toolchain and Servarr App Images).
    {
      description: 'Separate major updates into individual PRs for review',
      matchUpdateTypes: ['major'],
      groupName: null,
    },

    // Release branch maintenance: only patch-level updates.
    // Placed after all other rules so enabled:false wins.
    {
      description: 'Disable minor and major updates on release/* branches',
      matchBaseBranches: ['/^release\\//'],
      matchUpdateTypes: ['minor', 'major'],
      enabled: false,
    },
  ],

  // CVE fixes: vulnerabilityAlerts defaults give us separate PRs (groupName: null),
  // no release-age delay, and immediate creation. Security PRs also bypass
  // branchConcurrentLimit/prConcurrentLimit.
  vulnerabilityAlerts: {
    labels: ['dependencies', 'security'],
  },

  // Custom managers for non-standard dependency sources
  customManagers: [
    // Rust toolchain version in rust-toolchain.toml
    {
      customType: 'regex',
      managerFilePatterns: [
        '/(^|/)rust-toolchain\\.toml$/',
      ],
      matchStrings: [
        'channel\\s*=\\s*"(?<currentValue>\\d+\\.\\d+(\\.\\d+)?)"',
      ],
      depNameTemplate: 'rust',
      packageNameTemplate: 'rust-lang/rust',
      datasourceTemplate: 'github-releases',
    },

    // Container image tags in image-defaults.toml
    {
      customType: 'regex',
      managerFilePatterns: [
        '/(^|/)image-defaults\\.toml$/',
      ],
      matchStrings: [
        '\\[(?<depName>[a-z]+)\\]\\nrepository\\s*=\\s*"(?<packageName>[^"]+)"\\ntag\\s*=\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'docker',
    },
  ],

  // handle charts + template files as "Kubernetes" manager type
  kubernetes: {
    managerFilePatterns: [
      '/^chart\\/.+\\.ya?ml$/',
      '/^charts\\/.+\\.ya?ml$/',
    ],
  },
}
